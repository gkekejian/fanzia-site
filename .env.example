# Resend API key for contact form delivery.
# If unset, the contact API falls back to logging the submission and
# the UI surfaces a mailto: link so messages are never lost.
RESEND_API_KEY=

# Email address that receives contact form submissions.
CONTACT_TO_EMAIL=george@fanzia.io

# Verified sender address on your Resend account.
CONTACT_FROM_EMAIL=no-reply@fanzia.io
